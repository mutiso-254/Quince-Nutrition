# Frontend environment variables
# Copy this file to .env or .env.local and fill in the actual values
# Note: All VITE_* variables are embedded in the client bundle and publicly accessible

# =============================================================================
# API Configuration
# =============================================================================
# Backend API URL - defaults to localhost:8000 in development
VITE_API_URL=http://localhost:8000

# =============================================================================
# Sanity CMS Configuration
# =============================================================================
VITE_SANITY_PROJECT_ID=your_sanity_project_id
VITE_SANITY_DATASET=production

# =============================================================================
# Application Configuration
# =============================================================================
# Public URL of the application (used for meta tags, sharing, etc.)
VITE_APP_URL=http://localhost:3000

# =============================================================================
# WARNING: Do NOT add sensitive API keys here!
# =============================================================================
# Any VITE_* variable is public and readable in the browser.
# For sensitive operations, proxy through your backend API instead.
