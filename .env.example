# Backend environment variables
# place a file named `.env` at the project root with the values below.
# this file is gitignored (see `.gitignore`) so you can store secrets locally

# Django configuration
DJANGO_SECRET_KEY="your_django_secret_key_here"
# set this to False or leave unset in production;
# the dev defaults use DEBUG=True and localhost hosts
DJANGO_DEBUG="True"
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"
# override DJANGO_SETTINGS_MODULE if you need non-dev settings
# e.g. DJANGO_SETTINGS_MODULE=quince_project.settings.prod

# Airtable credentials
AIRTABLE_BASE_ID="your_airtable_base_id"
AIRTABLE_ACCESS_TOKEN="your_airtable_access_token"

# Email (SMTP) configuration
EMAIL_HOST="mail.example.com"
EMAIL_PORT="587"
EMAIL_USE_TLS="True"
EMAIL_USE_SSL="False"
EMAIL_HOST_USER="you@example.com"
EMAIL_HOST_PASSWORD="super-secret"
CONTACT_EMAIL_RECIPIENT="you@example.com"

# CitaPay Configuration
CITAPAY_API_KEY="sk_test_your_test_key_here"
CITAPAY_BASE_URL="http://localhost:4000"
CITAPAY_WEBHOOK_SECRET="your_webhook_secret_here"

# Frontend URL for payment redirects
FRONTEND_URL="http://localhost:5173"
